# DK-Control PWA Client .env Configuration
# Copy this file to .env.local and fill in the values

# API base URL (no trailing slash)
VITE_API_BASE_URL=https://your-server.example.com

# Optional: token name used when creating API tokens during login
VITE_TOKEN_NAME=DKC PWA

# Optional: token TTL in days (0 = unlimited)
VITE_TOKEN_TTL_DAYS=30
